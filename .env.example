# ==========================================
# Shadow Engineer - Global Environment Config
# Copy this file to .env and configure values
# ==========================================

# ------------------------------------------
# Next.js Frontend Configuration (apps/web)
# ------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000/api/v1

# ------------------------------------------
# Spring Boot Core Service (apps/core-service)
# ------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/shadow_engineer
SPRING_DATASOURCE_USERNAME=shadow_admin
SPRING_DATASOURCE_PASSWORD=shadow_secret_password

JWT_SECRET_KEY=replace_this_with_a_highly_secure_random_string_in_production
JWT_EXPIRATION_MS=86400000

GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret

# ------------------------------------------
# Python AI Service (apps/ai-service)
# ------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=optional_qdrant_key

REDIS_HOST=localhost
REDIS_PORT=6379

LOG_LEVEL=INFO
ENVIRONMENT=development
